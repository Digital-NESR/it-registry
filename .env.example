# ---- PostgreSQL connection ----
# Copy this file to .env.local and fill in your real values there.
# .env.local is gitignored, so secrets never get committed/pushed.
#
# Option A — individual parameters (use this if your password contains
# special characters like % or @, which are awkward to URL-encode):
POSTGRES_HOST=your-db-host.postgres.database.azure.com
POSTGRES_PORT=5432
POSTGRES_DB=it_registry
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password

# Option B — a single connection string (overrides the parameters above):
# DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# Most managed providers (Azure, Neon, Supabase, Vercel) require SSL.
PGSSL=true
